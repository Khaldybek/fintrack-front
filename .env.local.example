# Бэкенд API (порт 3000). Фронт запускается на 3001 (см. package.json "dev").
NEXT_PUBLIC_API_URL=http://localhost:3000
# С iPhone localhost недоступен: для проверки с телефона укажите LAN-IP или HTTPS-домен API
# (тот же хост, что в Google Cloud «Authorized redirect URIs» для OAuth).

# Для бэкенда: финальный редирект на фронт после Google должен открывать страницу callback,
# иначе сессия не поднимется (токены разбираются только на /auth/callback).
# Укажите полный URL с путём — не корень сайта:
# FRONTEND_URL=http://localhost:3001/auth/callback
#
# В Google Cloud Console в «Authorized redirect URIs» укажите URL бэкенда, который принимает
# код от Google; уже бэкенд редиректит браузер на FRONTEND_URL выше (с hash или query — оба поддерживаются).
